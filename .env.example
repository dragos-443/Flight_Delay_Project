PROJECT_NAME=flight-delay-project

# Local dataset path. Keep the real CSV out of Git.
DATASET_LOCAL_PATH=./data/raw/flight_data_2024.csv

# HDFS paths used by the local Docker environment.
HDFS_NAMENODE=hdfs://namenode:8020
HDFS_RAW_DIR=/data/raw
HDFS_PROCESSED_DIR=/data/processed
HDFS_OUTPUTS_DIR=/outputs

# Spark defaults.
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_APP_NAME=FlightDelayProject

# Hive defaults.
HIVE_HOST=hive-server
HIVE_PORT=10000

# Benchmark sample sizes.
SAMPLE_SIZES=100000,500000,1000000
